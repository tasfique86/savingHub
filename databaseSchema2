-- ─── STEP 3: Replace generate_monthly_ledger ────────────────
--  Now reads monthly_deposit, late_fine_amount, due_day from
--  club_settings and blocks months before the start date.

CREATE OR REPLACE FUNCTION generate_monthly_ledger(p_year INT, p_month INT)
RETURNS INT LANGUAGE plpgsql AS $$
DECLARE
  v_count        INT;
  v_start_year   SMALLINT;
  v_start_month  SMALLINT;
  v_deposit      DECIMAL(10,2);
  v_fine         DECIMAL(10,2);
  v_due_day      SMALLINT;
BEGIN
  SELECT savings_start_year, savings_start_month,
         monthly_deposit, late_fine_amount, due_day
  INTO   v_start_year, v_start_month, v_deposit, v_fine, v_due_day
  FROM   club_settings WHERE id = 1;

  -- Block if requested month is before club start
  IF (p_year < v_start_year)
    OR (p_year = v_start_year AND p_month < v_start_month)
  THEN
    RAISE NOTICE 'Skipped: %/% is before club start date %/%',
      p_month, p_year, v_start_month, v_start_year;
    RETURN 0;
  END IF;

  INSERT INTO monthly_ledger
    (member_id, year, month, required_amount, fine_amount, due_date, status)
  SELECT
    id,
    p_year::SMALLINT,
    p_month::SMALLINT,
    v_deposit,
    v_fine,
    MAKE_DATE(p_year, p_month, v_due_day),
    'due'
  FROM members
  WHERE is_active = TRUE
  ON CONFLICT (member_id, year, month) DO NOTHING;

  GET DIAGNOSTICS v_count = ROW_COUNT;
  RETURN v_count;
END;
$$;


-- ─── STEP 4: Replace recalculate_member_ledger ──────────────
--  Now reads start date from club_settings and skips months
--  that are before the club's savings start date.

CREATE OR REPLACE FUNCTION recalculate_member_ledger(p_member_id INT)
RETURNS VOID LANGUAGE plpgsql AS $$
DECLARE
  v_txn           RECORD;
  v_remaining     DECIMAL;
  v_ledger        RECORD;
  v_total_owed    DECIMAL;
  v_still_needed  DECIMAL;
  v_payment       DECIMAL;
  v_fine_exists   BOOLEAN;
  v_future_year   SMALLINT;
  v_future_month  SMALLINT;
  v_new_ledger_id INT;
  v_start_year    SMALLINT;
  v_start_month   SMALLINT;
  v_deposit       DECIMAL(10,2);
  v_fine_amt      DECIMAL(10,2);
  v_due_day       SMALLINT;
BEGIN
  -- Load club settings once
  SELECT savings_start_year, savings_start_month,
         monthly_deposit, late_fine_amount, due_day
  INTO   v_start_year, v_start_month, v_deposit, v_fine_amt, v_due_day
  FROM   club_settings WHERE id = 1;

  -- ── 1. Reset all ledger rows for this member ──────────────
  UPDATE monthly_ledger
  SET    status = 'due', amount_paid = 0, paid_date = NULL
  WHERE  member_id = p_member_id;

  -- ── 2. Reset fines ────────────────────────────────────────
  UPDATE fines
  SET    is_paid = FALSE, paid_date = NULL, transaction_id = NULL
  WHERE  member_id = p_member_id;

  -- ── 3. Reset credit balance ───────────────────────────────
  UPDATE members SET credit_balance = 0 WHERE id = p_member_id;

  -- ── 4. Replay all active transactions oldest-first ────────
  FOR v_txn IN
    SELECT id, amount, transaction_date, type
    FROM   transactions
    WHERE  member_id  = p_member_id
      AND  is_deleted = FALSE
    ORDER  BY transaction_date ASC, id ASC
  LOOP
    v_remaining := v_txn.amount;

    -- Pay off due/partial months — oldest first, start date respected
    FOR v_ledger IN
      SELECT
        ml.id, ml.year, ml.month,
        ml.required_amount, ml.fine_amount,
        ml.amount_paid, ml.due_date, ml.status,
        COALESCE(f.amount, v_fine_amt) AS fine_charge,
        COALESCE(f.is_paid, FALSE)     AS fine_paid,
        f.id                           AS fine_id
      FROM   monthly_ledger ml
      LEFT   JOIN fines f ON f.ledger_id = ml.id
      WHERE  ml.member_id = p_member_id
        AND  ml.status   IN ('due', 'partial')
        -- Only touch months on/after club start
        AND  (ml.year > v_start_year
              OR (ml.year = v_start_year AND ml.month >= v_start_month))
      ORDER  BY ml.year ASC, ml.month ASC
    LOOP
      EXIT WHEN v_remaining <= 0;

      v_fine_exists  := v_txn.transaction_date > v_ledger.due_date;
      v_total_owed   := v_ledger.required_amount
                        + CASE WHEN v_fine_exists THEN v_ledger.fine_charge ELSE 0 END;
      v_still_needed := v_total_owed - v_ledger.amount_paid;
      v_payment      := LEAST(v_remaining, v_still_needed);

      -- Create fine row if this is a late payment
      IF v_fine_exists THEN
        INSERT INTO fines (ledger_id, member_id, amount)
        VALUES (v_ledger.id, p_member_id, v_ledger.fine_charge)
        ON CONFLICT (ledger_id) DO NOTHING;
      END IF;

      -- Update ledger row
      UPDATE monthly_ledger
      SET
        amount_paid = amount_paid + v_payment,
        status = CASE
          WHEN (amount_paid + v_payment) >= v_total_owed THEN
            CASE WHEN v_txn.transaction_date > due_date
              THEN 'paid_late'::ledger_status
              ELSE 'paid_on_time'::ledger_status
            END
          ELSE 'partial'::ledger_status
        END,
        paid_date = CASE
          WHEN (amount_paid + v_payment) >= v_total_owed
          THEN v_txn.transaction_date
          ELSE NULL
        END
      WHERE id = v_ledger.id;

      -- Mark fine as paid if month is now fully settled
      IF (v_ledger.amount_paid + v_payment) >= v_total_owed THEN
        UPDATE fines
        SET    is_paid = TRUE,
               paid_date = v_txn.transaction_date,
               transaction_id = v_txn.id
        WHERE  ledger_id = v_ledger.id
          AND  is_paid   = FALSE;
      END IF;

      v_remaining := v_remaining - v_payment;
    END LOOP;

    -- ── Advance allocation ────────────────────────────────────
    WHILE v_remaining >= v_deposit LOOP

      -- Find the latest advance month already allocated
      SELECT year, month
      INTO   v_future_year, v_future_month
      FROM   monthly_ledger
      WHERE  member_id = p_member_id
        AND  status    = 'advance'
      ORDER  BY year DESC, month DESC
      LIMIT  1;

      IF NOT FOUND THEN
        -- No advance yet: start from next month after this transaction
        v_future_year  := EXTRACT(YEAR  FROM DATE_TRUNC('month', v_txn.transaction_date) + INTERVAL '1 month')::SMALLINT;
        v_future_month := EXTRACT(MONTH FROM DATE_TRUNC('month', v_txn.transaction_date) + INTERVAL '1 month')::SMALLINT;
      ELSE
        -- Increment past the last advance month
        IF v_future_month = 12 THEN
          v_future_year  := v_future_year + 1;
          v_future_month := 1;
        ELSE
          v_future_month := v_future_month + 1;
        END IF;
      END IF;

      -- Never create advance rows before club start date
      IF (v_future_year < v_start_year)
        OR (v_future_year = v_start_year AND v_future_month < v_start_month)
      THEN
        -- Store remaining as credit instead
        UPDATE members
        SET credit_balance = credit_balance + v_remaining
        WHERE id = p_member_id;
        v_remaining := 0;
        EXIT;
      END IF;

      INSERT INTO monthly_ledger
        (member_id, year, month, required_amount, fine_amount, due_date, status, amount_paid)
      VALUES
        (p_member_id,
         v_future_year, v_future_month,
         v_deposit, v_fine_amt,
         MAKE_DATE(v_future_year::INT, v_future_month::INT, v_due_day),
         'advance', v_deposit)
      ON CONFLICT (member_id, year, month) DO UPDATE
        SET status      = 'advance',
            amount_paid = v_deposit,
            paid_date   = v_txn.transaction_date
      RETURNING id INTO v_new_ledger_id;

      v_remaining := v_remaining - v_deposit;
    END LOOP;

    -- Store leftover < monthly_deposit as credit
    IF v_remaining > 0 THEN
      UPDATE members
      SET credit_balance = credit_balance + v_remaining
      WHERE id = p_member_id;
    END IF;

  END LOOP;
END;
$$;


-- ─── STEP 5: Replace allocate_deposit ───────────────────────
--  Now reads monthly_deposit + due_day from club_settings.
--  Also auto-generates the ledger row if it doesn't exist yet.

CREATE OR REPLACE FUNCTION allocate_deposit(
  p_member_id        INT,
  p_amount           DECIMAL,
  p_transaction_date DATE,
  p_notes            TEXT DEFAULT NULL
)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE
  v_txn_id      INT;
  v_before      JSONB;
  v_after       JSONB;
  v_start_year  SMALLINT;
  v_start_month SMALLINT;
  v_deposit     DECIMAL(10,2);
  v_fine_amt    DECIMAL(10,2);
  v_due_day     SMALLINT;
  v_cur_year    SMALLINT;
  v_cur_month   SMALLINT;
BEGIN
  -- Load settings
  SELECT savings_start_year, savings_start_month,
         monthly_deposit, late_fine_amount, due_day
  INTO   v_start_year, v_start_month, v_deposit, v_fine_amt, v_due_day
  FROM   club_settings WHERE id = 1;

  v_cur_year  := EXTRACT(YEAR  FROM p_transaction_date)::SMALLINT;
  v_cur_month := EXTRACT(MONTH FROM p_transaction_date)::SMALLINT;

  -- Ensure a ledger row exists for the deposit month (if on/after start)
  IF (v_cur_year > v_start_year)
    OR (v_cur_year = v_start_year AND v_cur_month >= v_start_month)
  THEN
    INSERT INTO monthly_ledger
      (member_id, year, month, required_amount, fine_amount, due_date, status)
    VALUES
      (p_member_id, v_cur_year, v_cur_month, v_deposit, v_fine_amt,
       MAKE_DATE(v_cur_year::INT, v_cur_month::INT, v_due_day), 'due')
    ON CONFLICT (member_id, year, month) DO NOTHING;
  END IF;

  -- Snapshot before state
  SELECT jsonb_agg(jsonb_build_object(
    'month', month, 'year', year, 'status', status, 'amount_paid', amount_paid
  ))
  INTO v_before
  FROM monthly_ledger WHERE member_id = p_member_id;

  -- Insert the transaction
  INSERT INTO transactions (member_id, amount, transaction_date, type, notes)
  VALUES (p_member_id, p_amount, p_transaction_date, 'deposit', p_notes)
  RETURNING id INTO v_txn_id;

  -- Recalculate entire ledger
  PERFORM recalculate_member_ledger(p_member_id);

  -- Snapshot after state
  SELECT jsonb_agg(jsonb_build_object(
    'month', month, 'year', year, 'status', status, 'amount_paid', amount_paid
  ))
  INTO v_after
  FROM monthly_ledger WHERE member_id = p_member_id;

  RETURN jsonb_build_object(
    'transaction_id', v_txn_id,
    'member_id',      p_member_id,
    'amount',         p_amount,
    'ledger_before',  v_before,
    'ledger_after',   v_after
  );
END;
$$;


