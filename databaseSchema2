-- ─── STEP 1: Create club_settings table ─────────────────────

CREATE TABLE IF NOT EXISTS club_settings (
  id                   INT           PRIMARY KEY DEFAULT 1,
  club_name            VARCHAR(100)  NOT NULL DEFAULT 'Saving Hub',
  savings_start_year   SMALLINT      NOT NULL,
  savings_start_month  SMALLINT      NOT NULL CHECK (savings_start_month BETWEEN 1 AND 12),
  monthly_deposit      DECIMAL(10,2) NOT NULL DEFAULT 500.00,
  late_fine_amount     DECIMAL(10,2) NOT NULL DEFAULT 50.00,
  due_day              SMALLINT      NOT NULL DEFAULT 10,
  created_at           TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
  updated_at           TIMESTAMPTZ   NOT NULL DEFAULT NOW(),

  CONSTRAINT single_row CHECK (id = 1)
);

-- Trigger for updated_at
CREATE TRIGGER ts_club_settings
  BEFORE UPDATE ON club_settings
  FOR EACH ROW EXECUTE FUNCTION trigger_set_timestamp();

